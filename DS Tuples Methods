# .count()
# count(value) returns how many times a value appears in the tuple

basket = ('Apple', 'Banana', 'Mango', 'Orange', 'Apple')
print(basket.count('Apple'))  # 2 → 'Apple' appears two times

basket = ('Apple', 'Banana', 'Mango', 'Orange', 'Apple')
print(basket.count('Pineapple'))  
# 0 → 'Pineapple' does not exist in the tuple

